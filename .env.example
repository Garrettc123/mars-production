# MARS API — required environment variables
# Copy this file to .env and fill in real values before running.

# Anthropic API key — used by MARS to call Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Secret key clients must supply in the X-Api-Key header
MARS_API_KEY=your_mars_api_key_here

# Port the server listens on (default: 8000)
PORT=8000
